# Frontend Environment Variables
FRONTEND_PORT=7000
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
PUBLIC_FRONTEND_HOSTNAME=localhost
PUBLIC_PLATFORM_HOSTNAME=localhost
PUBLIC_IDP_HOSTNAME=localhost

# AxiomNizam IAM Configuration (replaces Keycloak)
IAM_SYSADMIN_EMAIL=sysadmin@axiomnizam.local
IAM_SYSADMIN_PASSWORD=changeme-on-first-login
IAM_ISSUER_URL=http://localhost:8000
# IAM_RSA_PRIVATE_KEY_FILE=/path/to/rsa-private.pem   # Optional: persistent RSA key
# IAM_ACCESS_TOKEN_TTL=15m                             # Default: 15 minutes
# IAM_REFRESH_TOKEN_TTL=168h                           # Default: 7 days

# Legacy Keycloak Configuration (deprecated — use IAM instead)
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=axiomnizam
# KEYCLOAK_CLIENT_ID=axiomnizam-frontend
# KEYCLOAK_REDIRECT_URI=http://localhost:7000/callback

# Production example values:
# PUBLIC_FRONTEND_HOSTNAME=axiomnizam.bitbd.net
# PUBLIC_PLATFORM_HOSTNAME=axiomnizam-platfrom.bitbd.net
# PUBLIC_IDP_HOSTNAME=idp.bitbd.net
# BACKEND_URL=https://axiomnizam-platfrom.bitbd.net
# IAM_ISSUER_URL=https://axiomnizam-platfrom.bitbd.net
