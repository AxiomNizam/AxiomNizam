# Frontend Environment Variables
FRONTEND_PORT=7000
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
PUBLIC_FRONTEND_HOSTNAME=localhost
PUBLIC_PLATFORM_HOSTNAME=localhost
PUBLIC_IDP_HOSTNAME=localhost

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=axiomnizam
KEYCLOAK_CLIENT_ID=axiomnizam-frontend
KEYCLOAK_REDIRECT_URI=http://localhost:7000/callback

# Production example values:
# PUBLIC_FRONTEND_HOSTNAME=axiomnizam.bitbd.net
# PUBLIC_PLATFORM_HOSTNAME=axiomnizam-platfrom.bitbd.net
# PUBLIC_IDP_HOSTNAME=idp.bitbd.net
# BACKEND_URL=https://axiomnizam-platfrom.bitbd.net
# KEYCLOAK_URL=https://idp.bitbd.net
# KEYCLOAK_REDIRECT_URI=https://axiomnizam.bitbd.net/callback
