# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Security guardrails rollout (staging first)
# 1) Keep environment as production profile in staging to validate real guardrails.
# 2) Start with audit mode and fix all guardrail warnings/issues from logs.
# 3) After logs are clean, switch mode to enforce.
AXIOMNIZAM_ENV=production
SECURITY_GUARDRAILS_MODE=audit
# SECURITY_GUARDRAILS_MODE=enforce

# Public URL / Hostname Configuration
PUBLIC_FRONTEND_HOSTNAME=localhost
PUBLIC_PLATFORM_HOSTNAME=localhost
PUBLIC_IDP_HOSTNAME=localhost
PUBLIC_FRONTEND_URL=http://localhost:7000
PUBLIC_PLATFORM_URL=http://localhost:8000
PUBLIC_IDP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:7000,http://127.0.0.1:7000
KC_HTTP_ENABLED=true
KC_HTTP_RELATIVE_PATH=/
KC_HOSTNAME_ADMIN=http://localhost:8080
KC_HOSTNAME=http://localhost:8080
FRONTEND_PORT=7000
KEYCLOAK_FRONTEND_CLIENT_ID=axiomnizam-frontend
KEYCLOAK_FRONTEND_REDIRECT_URI=http://localhost:7000/callback

# OpenClaw Gateway / SQL Assistant Configuration
# Docker service host for inter-container access
OPENCLAW_HOST=openclaw-gateway
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=dev-openclaw-token
OPENCLAW_OLLAMA_BASE_URL=http://ollama:11434
OPENCLAW_OLLAMA_MODEL_ID=tinyllama
OPENCLAW_OLLAMA_MODEL_REF=ollama/tinyllama
OLLAMA_API_KEY=ollama-local
# Backend SQL assistant endpoint and auth token
OPENCLAW_SQL_ASSISTANT_URL=http://openclaw-gateway:18789/v1/chat/completions
OPENCLAW_SQL_ASSISTANT_TOKEN=dev-openclaw-token
OPENCLAW_SQL_ASSISTANT_MODEL=ollama/tinyllama
OPENCLAW_SQL_ASSISTANT_TIMEOUT_SECONDS=90

# Certificate lifecycle management (kubeadm-style)
# Modes: kubeadm (default) or tls
CERT_MANAGER_MODE=kubeadm
# Kubernetes PKI directory used for kubeadm-style cert checks
CERT_PKI_DIR=/etc/kubernetes/pki
# Managed cert names (comma-separated). Use names supported by kubeadm renew.
CERT_MANAGED_CERTS=apiserver,apiserver-kubelet-client,apiserver-etcd-client,front-proxy-client,etcd-server,etcd-peer,etcd-healthcheck-client
# Renew recommendation threshold (days before expiry). Set 365 for yearly reminder/renewal planning.
CERT_RENEWAL_THRESHOLD_DAYS=30
# Optional override command. Supports {{cert}} placeholder.
# Example: kubeadm certs renew {{cert}}
CERT_RENEW_COMMAND=
# TLS mode only: comma-separated host[:port] targets
CERT_MONITOR_TARGETS=idp.bitbd.net:443

# MySQL Configuration
MYSQL_HOST=mysql8
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=app_db

# MariaDB Configuration
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=root
MARIADB_DATABASE=app_db

# Percona Configuration
PERCONA_HOST=percona
PERCONA_PORT=3306
PERCONA_USER=root
PERCONA_PASSWORD=root
PERCONA_DATABASE=bhtpsv2_prod

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=app_db
POSTGRES_SSLMODE=disable

# MongoDB Configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=root
MONGODB_PASSWORD=root
MONGODB_DATABASE=app_db

# Valkey/Redis Configuration
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URL=amqp://axiom:axiom@rabbitmq:5672/
RABBITMQ_USER=axiom
RABBITMQ_PASSWORD=axiom
RABBITMQ_VHOST=/axiom

# Kafka Configuration
KAFKA_BROKERS=kafka:9092

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

