{
	"info": {
		"name": "Query Logger Enterprise Endpoints",
		"description": "Enterprise-grade query logging and analytics endpoints for AxiomNizam",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"version": "1.0.0"
	},
	"item": [
		{
			"name": "Enterprise Statistics",
			"item": [
				{
					"name": "Get Overall System Metrics",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has required fields', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.equal('ok');",
									"    pm.expect(jsonData.data).to.have.all.keys('total_queries', 'success_count', 'error_count', 'success_rate', 'avg_duration', 'total_duration', 'total_rows', 'by_database', 'by_user', 'by_query_type');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/query/stats/enterprise",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"query",
								"stats",
								"enterprise"
							]
						},
						"description": "Get comprehensive system-wide query metrics including success rates, average duration, and breakdowns by database, user, and query type."
					},
					"response": []
				}
			]
		},
		{
			"name": "Performance Monitoring",
			"item": [
				{
					"name": "Get Slow Queries",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Slow queries returned correctly', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.equal('ok');",
									"    pm.expect(jsonData.data).to.have.property('slow_queries');",
									"    pm.expect(jsonData.data).to.have.property('threshold');",
									"    pm.expect(jsonData.data).to.have.property('count');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/query/slow?database=production&threshold=1000&limit=50",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"query",
								"slow"
							],
							"query": [
								{
									"key": "database",
									"value": "production",
									"description": "Database name or 'all' for all databases"
								},
								{
									"key": "threshold",
									"value": "1000",
									"description": "Duration threshold in milliseconds (default: 1000)"
								},
								{
									"key": "limit",
									"value": "50",
									"description": "Maximum results to return (default: 100, max: 1000)"
								}
							]
						},
						"description": "Retrieve queries that exceeded the specified execution time threshold, useful for identifying performance bottlenecks."
					},
					"response": []
				},
