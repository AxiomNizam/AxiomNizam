{
  "info": {
    "name": "AxiomNizam - Query Logger",
    "description": "Query logging and statistics endpoints for all 5 SQL databases. View query execution logs and performance statistics per database.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "MySQL Logs & Stats",
      "item": [
        { "name": "Get Query Logs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mysql/logs", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "logs"] }, "description": "Get all query execution logs for MySQL" }, "response": [] },
        { "name": "Get Query Stats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mysql/stats", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "stats"] }, "description": "Get query performance statistics for MySQL" }, "response": [] }
      ]
    },
    {
      "name": "MariaDB Logs & Stats",
      "item": [
        { "name": "Get Query Logs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mariadb/logs", "host": ["{{BASE_URL}}"], "path": ["api", "mariadb", "logs"] } }, "response": [] },
        { "name": "Get Query Stats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mariadb/stats", "host": ["{{BASE_URL}}"], "path": ["api", "mariadb", "stats"] } }, "response": [] }
      ]
    },
    {
      "name": "PostgreSQL Logs & Stats",
      "item": [
        { "name": "Get Query Logs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/postgres/logs", "host": ["{{BASE_URL}}"], "path": ["api", "postgres", "logs"] } }, "response": [] },
        { "name": "Get Query Stats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/postgres/stats", "host": ["{{BASE_URL}}"], "path": ["api", "postgres", "stats"] } }, "response": [] }
      ]
    },
    {
      "name": "Percona Logs & Stats",
      "item": [
        { "name": "Get Query Logs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/percona/logs", "host": ["{{BASE_URL}}"], "path": ["api", "percona", "logs"] } }, "response": [] },
        { "name": "Get Query Stats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/percona/stats", "host": ["{{BASE_URL}}"], "path": ["api", "percona", "stats"] } }, "response": [] }
      ]
    },
    {
      "name": "Oracle Logs & Stats",
      "item": [
        { "name": "Get Query Logs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/oracle/logs", "host": ["{{BASE_URL}}"], "path": ["api", "oracle", "logs"] } }, "response": [] },
        { "name": "Get Query Stats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/oracle/stats", "host": ["{{BASE_URL}}"], "path": ["api", "oracle", "stats"] } }, "response": [] }
      ]
    }
  ]
}
