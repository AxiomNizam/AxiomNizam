        { "name": "POST Query (Parameterized)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"query\": \"SELECT * FROM users WHERE age > :1\",\n  \"params\": [25]\n}" }, "url": { "raw": "{{BASE_URL}}/api/oracle/query", "host": ["{{BASE_URL}}"], "path": ["api", "oracle", "query"] } }, "response": [] },
