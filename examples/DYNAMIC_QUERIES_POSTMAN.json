    {
      "name": "Advanced Query Examples",
      "item": [
        {
          "name": "Count Users by Age",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"SELECT age, COUNT(*) as count FROM users GROUP BY age HAVING COUNT(*) > ?\",\n  \"params\": [1]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "Pagination Example",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"SELECT * FROM users ORDER BY id DESC LIMIT ? OFFSET ?\",\n  \"params\": [10, 0]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "Search with Wildcards",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"SELECT * FROM users WHERE name LIKE ? OR email LIKE ?\",\n  \"params\": [\"%john%\", \"%@example.com\"]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "Aggregate Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"SELECT MIN(age) as min_age, MAX(age) as max_age, AVG(age) as avg_age FROM users\",\n  \"params\": []\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        }
      ]
    }
  ]
}
