{
  "info": {
    "name": "AxiomNizam - Dynamic Queries",
    "description": "Dynamic SQL query endpoints for all 5 SQL databases: MySQL, MariaDB, PostgreSQL, Percona, and Oracle. Supports GET/POST queries, batch operations, and schema inspection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "MySQL Queries",
      "item": [
        { "name": "GET Query", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mysql/query?q=SELECT * FROM users LIMIT 10", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "query"], "query": [{ "key": "q", "value": "SELECT * FROM users LIMIT 10" }] } }, "response": [] },
        { "name": "POST Query (Parameterized)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"query\": \"SELECT * FROM users WHERE age > ? AND name LIKE ?\",\n  \"params\": [25, \"%john%\"]\n}" }, "url": { "raw": "{{BASE_URL}}/api/mysql/query", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "query"] } }, "response": [] },
        { "name": "Batch Queries", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "[\n  {\"query\": \"SELECT COUNT(*) as total FROM users\", \"params\": []},\n  {\"query\": \"SELECT * FROM users WHERE age > ?\", \"params\": [25]},\n  {\"query\": \"SELECT AVG(age) as avg_age FROM users\", \"params\": []}\n]" }, "url": { "raw": "{{BASE_URL}}/api/mysql/query/batch", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "query", "batch"] } }, "response": [] },
        { "name": "Get Table Schema", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mysql/schema?table=users", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "schema"], "query": [{ "key": "table", "value": "users" }] } }, "response": [] }
      ]
    },
    {
      "name": "MariaDB Queries",
      "item": [
        { "name": "GET Query", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mariadb/query?q=SELECT * FROM users LIMIT 10", "host": ["{{BASE_URL}}"], "path": ["api", "mariadb", "query"], "query": [{ "key": "q", "value": "SELECT * FROM users LIMIT 10" }] } }, "response": [] },
        { "name": "POST Query (Parameterized)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"query\": \"SELECT * FROM users WHERE age > ? AND name LIKE ?\",\n  \"params\": [25, \"%jane%\"]\n}" }, "url": { "raw": "{{BASE_URL}}/api/mariadb/query", "host": ["{{BASE_URL}}"], "path": ["api", "mariadb", "query"] } }, "response": [] },
        { "name": "Batch Queries", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "[\n  {\"query\": \"SELECT COUNT(*) as total FROM users\", \"params\": []},\n  {\"query\": \"SELECT * FROM users WHERE age > ?\", \"params\": [30]}\n]" }, "url": { "raw": "{{BASE_URL}}/api/mariadb/query/batch", "host": ["{{BASE_URL}}"], "path": ["api", "mariadb", "query", "batch"] } }, "response": [] },
        { "name": "Get Table Schema", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mariadb/schema?table=users", "host": ["{{BASE_URL}}"], "path": ["api", "mariadb", "schema"], "query": [{ "key": "table", "value": "users" }] } }, "response": [] }
