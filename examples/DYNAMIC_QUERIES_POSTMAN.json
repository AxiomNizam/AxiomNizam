{
  "info": {
    "_postman_id": "dynamic-queries-collection",
    "name": "AxiomNizam - Dynamic Queries",
    "description": "Dynamic SQL Query Examples for AxiomNizam",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "MySQL Dynamic Queries",
      "item": [
        {
          "name": "GET - Select All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/mysql/query?q=SELECT * FROM users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"],
              "query": [
                {
                  "key": "q",
                  "value": "SELECT * FROM users"
                }
              ]
            }
          }
        },
        {
          "name": "GET - Select by Age",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/mysql/query?q=SELECT * FROM users WHERE age > ?&params=25",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"],
              "query": [
                {
                  "key": "q",
                  "value": "SELECT * FROM users WHERE age > ?"
                },
                {
                  "key": "params",
                  "value": "25"
                }
              ]
            }
          }
        },
        {
          "name": "POST - Select with Multiple Parameters",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"SELECT * FROM users WHERE age > ? AND name LIKE ?\",\n  \"params\": [25, \"%John%\"]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "POST - Insert User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"INSERT INTO users (name, email, age) VALUES (?, ?, ?)\",\n  \"params\": [\"Alice Smith\", \"alice@example.com\", 28]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "POST - Update User Age",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"UPDATE users SET age = ? WHERE id = ?\",\n  \"params\": [30, 1]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "POST - Delete User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"DELETE FROM users WHERE id = ?\",\n  \"params\": [1]\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query"]
            }
          }
        },
        {
          "name": "GET - Table Schema",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/mysql/schema?table=users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "schema"],
              "query": [
                {
                  "key": "table",
                  "value": "users"
                }
              ]
            }
          }
        },
        {
          "name": "POST - Batch Queries",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"query\": \"SELECT COUNT(*) as total FROM users\",\n    \"params\": []\n  },\n  {\n    \"query\": \"SELECT * FROM users WHERE age > ? LIMIT ?\",\n    \"params\": [25, 5]\n  },\n  {\n    \"query\": \"INSERT INTO users (name, email, age) VALUES (?, ?, ?)\",\n    \"params\": [\"Bob Johnson\", \"bob@example.com\", 27]\n  }\n]"
            },
            "url": {
              "raw": "http://localhost:8000/api/mysql/query/batch",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "mysql", "query", "batch"]
            }
          }
        }
      ]
    },
