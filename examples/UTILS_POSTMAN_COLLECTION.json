{
  "info": {
    "name": "AxiomNizam - Utilities & System",
    "description": "System utility endpoints including health checks, notifications, CLI authentication, and K8s-style resource management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Notifications",
      "item": [
        { "name": "Send Notification", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"message\": \"Test notification from AxiomNizam\",\n  \"level\": \"info\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/notifications/send", "host": ["{{BASE_URL}}"], "path": ["api", "notifications", "send"] } }, "response": [] },
        { "name": "Send Health Notification", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{}" }, "url": { "raw": "{{BASE_URL}}/api/notifications/health", "host": ["{{BASE_URL}}"], "path": ["api", "notifications", "health"] } }, "response": [] },
        { "name": "Send Status Notification", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{}" }, "url": { "raw": "{{BASE_URL}}/api/notifications/status", "host": ["{{BASE_URL}}"], "path": ["api", "notifications", "status"] } }, "response": [] },
        { "name": "Get Notification Status (No Auth)", "request": { "method": "GET", "header": [], "url": { "raw": "{{BASE_URL}}/api/notifications/status", "host": ["{{BASE_URL}}"], "path": ["api", "notifications", "status"] }, "description": "GET request to check notification service status (no authentication required)" }, "response": [] }
      ]
    },
    {
      "name": "CLI Authentication",
      "item": [
        { "name": "CLI Login", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "auth", "login"] } }, "response": [] },
        { "name": "CLI Verify Token", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/auth/verify", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "auth", "verify"] } }, "response": [] },
        { "name": "CLI WhoAmI", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/auth/whoami", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "auth", "whoami"] } }, "response": [] }
      ]
    },
    {
      "name": "K8s-Style Resources",
      "item": [
        { "name": "Create Resource", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"apiVersion\": \"v1\",\n  \"kind\": \"workloads\",\n  \"metadata\": {\"name\": \"test-workload\", \"namespace\": \"default\"},\n  \"spec\": {\"replicas\": 3, \"image\": \"nginx:latest\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads"] } }, "response": [] },
        { "name": "List Resources", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads"] } }, "response": [] },
        { "name": "Get Resource", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads/test-workload", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads", "test-workload"] } }, "response": [] },
        { "name": "Update Resource", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"spec\": {\"replicas\": 5}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads/test-workload", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads", "test-workload"] } }, "response": [] },
        { "name": "Delete Resource", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads/test-workload", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads", "test-workload"] } }, "response": [] },
        { "name": "Get Resource Status", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads/test-workload/status", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads", "test-workload", "status"] } }, "response": [] },
        { "name": "Get Resource Events", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/namespaces/default/workloads/test-workload/events", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "namespaces", "default", "workloads", "test-workload", "events"] } }, "response": [] }
      ]
    },
    {
      "name": "Non-namespaced Resources",
      "item": [
        { "name": "Create API", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"apiVersion\": \"v1\",\n  \"kind\": \"apis\",\n  \"metadata\": {\"name\": \"my-api\"},\n  \"spec\": {\"path\": \"/custom-endpoint\", \"method\": \"GET\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/apis", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "apis"] } }, "response": [] },
        { "name": "List APIs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/apis", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "apis"] } }, "response": [] },
        { "name": "Create Policy", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"apiVersion\": \"v1\",\n  \"kind\": \"policies\",\n  \"metadata\": {\"name\": \"rate-limit\"},\n  \"spec\": {\"maxRequests\": 100, \"window\": \"1m\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/policies", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "policies"] } }, "response": [] },
        { "name": "List Policies", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/policies", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "policies"] } }, "response": [] },
        { "name": "Create Workflow", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"apiVersion\": \"v1\",\n  \"kind\": \"workflows\",\n  \"metadata\": {\"name\": \"data-pipeline\"},\n  \"spec\": {\"steps\": [{\"name\": \"extract\"}, {\"name\": \"transform\"}]}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/workflows", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "workflows"] } }, "response": [] },
        { "name": "List Workflows", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/workflows", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "workflows"] } }, "response": [] },
        { "name": "Run Workflow", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/workflows/data-pipeline/run", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "workflows", "data-pipeline", "run"] } }, "response": [] }
      ]
    },
    {
      "name": "DataSources",
      "item": [
        { "name": "Create DataSource", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"my-postgres\",\n  \"type\": \"postgresql\",\n  \"host\": \"localhost\",\n  \"port\": 5432,\n  \"database\": \"mydb\",\n  \"username\": \"user\",\n  \"password\": \"pass\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/datasources", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "datasources"] } }, "response": [] },
        { "name": "List DataSources", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/datasources", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "datasources"] } }, "response": [] },
        { "name": "Get DataSource", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/datasources/my-postgres", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "datasources", "my-postgres"] } }, "response": [] },
        { "name": "Update DataSource", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"host\": \"db.example.com\",\n  \"database\": \"production\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/datasources/my-postgres", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "datasources", "my-postgres"] } }, "response": [] },
        { "name": "Delete DataSource", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/datasources/my-postgres", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "datasources", "my-postgres"] } }, "response": [] },
        { "name": "Test Connection", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/datasources/my-postgres/test", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "datasources", "my-postgres", "test"] } }, "response": [] }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        { "name": "Create Job", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"data-sync\",\n  \"type\": \"sync\",\n  \"schedule\": \"*/5 * * * *\",\n  \"config\": {\"source\": \"mysql\", \"target\": \"postgres\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/jobs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs"] } }, "response": [] },
        { "name": "List Jobs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/jobs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs"] } }, "response": [] },
        { "name": "Get Job", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/jobs/job-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs", "job-001"] } }, "response": [] },
        { "name": "Run Job", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/jobs/job-001/run", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs", "job-001", "run"] } }, "response": [] },
        { "name": "Get Job Logs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/jobs/job-001/logs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs", "job-001", "logs"] } }, "response": [] },
        { "name": "Cancel Job", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/jobs/job-001/cancel", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs", "job-001", "cancel"] } }, "response": [] },
        { "name": "Delete Job", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/jobs/job-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "jobs", "job-001"] } }, "response": [] }
      ]
    }
  ]
}
