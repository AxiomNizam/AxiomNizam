              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/admin/metrics/all",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "admin", "metrics", "all"]
            },
            "description": "Look at endpoints array and sort by total_calls (highest first)"
          },
          "response": []
        },
        {
          "name": "3. Which API is the slowest?",
          "request": {
