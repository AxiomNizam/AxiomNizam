                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/admin/metrics/all",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "admin", "metrics", "all"]
            },
            "description": "Look at endpoints array and sort by max_duration_ms (highest first)"
          },
          "response": []
        },
        {
          "name": "4. Which API has the most errors?",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/admin/metrics/all",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "admin", "metrics", "all"]
            },
            "description": "Look at endpoints array and sort by error_calls (highest first)"
          },
          "response": []
        },
        {
          "name": "5. What's the total API usage count?",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/admin/metrics/count",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "admin", "metrics", "count"]
            },
            "description": "Check total_api_calls in response"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "admin_token",
      "value": "your_admin_jwt_token_here",
      "type": "string"
    }
  ]
}
