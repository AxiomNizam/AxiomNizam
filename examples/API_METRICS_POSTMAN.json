{
  "info": {
    "name": "AxiomNizam - API Metrics",
    "description": "Admin API metrics endpoints for monitoring all API usage, request counts, and performance statistics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Admin Database Operations",
      "item": [
        { "name": "Create Database", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }], "body": { "mode": "raw", "raw": "{\n  \"database\": \"mysql\",\n  \"name\": \"analytics_db\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/admin/database/create", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "database", "create"] } }, "response": [] },
        { "name": "List Databases", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }], "url": { "raw": "{{BASE_URL}}/api/admin/database/list", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "database", "list"] } }, "response": [] },
        { "name": "Create Table", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" }], "body": { "mode": "raw", "raw": "{\n  \"database\": \"mysql\",\n  \"table_name\": \"metrics_log\",\n  \"columns\": [\n    {\"name\": \"id\", \"type\": \"INT\", \"primary_key\": true, \"auto_increment\": true},\n    {\"name\": \"endpoint\", \"type\": \"VARCHAR(500)\"},\n    {\"name\": \"method\", \"type\": \"VARCHAR(10)\"},\n    {\"name\": \"response_time_ms\", \"type\": \"INT\"},\n    {\"name\": \"status_code\", \"type\": \"INT\"},\n    {\"name\": \"created_at\", \"type\": \"TIMESTAMP\"}\n  ]\n}" }, "url": { "raw": "{{BASE_URL}}/api/admin/table/create", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "table", "create"] } }, "response": [] },
        { "name": "List Tables", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }], "url": { "raw": "{{BASE_URL}}/api/admin/table/list", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "table", "list"] } }, "response": [] }
      ]
    },
    {
      "name": "API Metrics",
      "item": [
        { "name": "Get All Metrics", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }], "url": { "raw": "{{BASE_URL}}/api/admin/metrics/all", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "metrics", "all"] }, "description": "Get comprehensive metrics for all API endpoints including request counts, response times, error rates" }, "response": [] },
        { "name": "Get API Count", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }], "url": { "raw": "{{BASE_URL}}/api/admin/metrics/count", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "metrics", "count"] }, "description": "Get total count of registered API endpoints" }, "response": [] },
        { "name": "Get API Stats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }], "url": { "raw": "{{BASE_URL}}/api/admin/metrics/stats", "host": ["{{BASE_URL}}"], "path": ["api", "admin", "metrics", "stats"] }, "description": "Get aggregated statistics: avg response time, p95 latency, error rate, throughput" }, "response": [] }
      ]
    }
  ]
}
