{
  "info": {
    "name": "AxiomNizam - CDC & ETL Pipelines",
    "description": "Change Data Capture (CDC) and Extract-Transform-Load (ETL) pipeline management. Includes pipeline CRUD, execution, observability, connectors, and the unified data platform overview.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "ETL Pipelines",
      "item": [
        { "name": "List Pipelines", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/pipelines", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "pipelines"] } }, "response": [] },
        { "name": "Get Pipeline", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/pipelines/etl-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "pipelines", "etl-001"] } }, "response": [] },
        { "name": "Create Pipeline", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"MySQL to PostgreSQL Sync\",\n  \"description\": \"Sync users table from MySQL to PostgreSQL\",\n  \"source\": {\n    \"type\": \"mysql\",\n    \"config\": {\"table\": \"users\", \"database\": \"app_db\"}\n  },\n  \"destination\": {\n    \"type\": \"postgresql\",\n    \"config\": {\"table\": \"users_copy\", \"database\": \"analytics_db\"}\n  },\n  \"transformations\": [\n    {\"type\": \"rename\", \"config\": {\"first_name\": \"firstName\"}}\n  ],\n  \"schedule\": \"0 */6 * * *\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/etl/pipelines", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "pipelines"] } }, "response": [] },
        { "name": "Update Pipeline", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"MySQL to PostgreSQL Sync (Updated)\",\n  \"schedule\": \"0 */12 * * *\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/etl/pipelines/etl-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "pipelines", "etl-001"] } }, "response": [] },
        { "name": "Delete Pipeline", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/pipelines/etl-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "pipelines", "etl-001"] } }, "response": [] },
        { "name": "Run Pipeline", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/pipelines/etl-001/run", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "pipelines", "etl-001", "run"] } }, "response": [] }
      ]
    },
    {
      "name": "ETL Runs",
      "item": [
        { "name": "List Runs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/runs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "runs"] } }, "response": [] },
        { "name": "Get Run Details", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/runs/run-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "runs", "run-001"] } }, "response": [] }
      ]
    },
    {
      "name": "ETL Connectors & Observability",
      "item": [
        { "name": "List Connectors", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/connectors", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "connectors"] }, "description": "List available ETL source and destination connectors" }, "response": [] },
        { "name": "ETL Observability", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/etl/observability", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "etl", "observability"] }, "description": "Get ETL pipeline metrics, throughput, and health" }, "response": [] }
      ]
    },
    {
      "name": "CDC Pipelines",
      "item": [
        { "name": "List Pipelines", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines"] } }, "response": [] },
        { "name": "Get Pipeline", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines/cdc-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines", "cdc-001"] } }, "response": [] },
        { "name": "Create Pipeline", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"MySQL CDC Stream\",\n  \"description\": \"Stream changes from MySQL users and orders tables\",\n  \"source\": {\n    \"type\": \"mysql-binlog\",\n    \"config\": {\n      \"tables\": [\"users\", \"orders\"],\n      \"server_id\": 1001\n    }\n  },\n  \"sink\": {\n    \"type\": \"kafka\",\n    \"config\": {\n      \"topic\": \"cdc-events\",\n      \"bootstrap_servers\": \"localhost:9092\"\n    }\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines"] } }, "response": [] },
        { "name": "Update Pipeline", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"MySQL CDC Stream (v2)\",\n  \"sink\": {\"type\": \"kafka\", \"config\": {\"topic\": \"cdc-events-v2\"}}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines/cdc-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines", "cdc-001"] } }, "response": [] },
        { "name": "Delete Pipeline", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines/cdc-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines", "cdc-001"] } }, "response": [] }
      ]
    },
    {
      "name": "CDC Pipeline Controls",
      "item": [
        { "name": "Start Pipeline", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines/cdc-001/start", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines", "cdc-001", "start"] } }, "response": [] },
        { "name": "Pause Pipeline", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines/cdc-001/pause", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines", "cdc-001", "pause"] } }, "response": [] },
        { "name": "Stop Pipeline", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/pipelines/cdc-001/stop", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "pipelines", "cdc-001", "stop"] } }, "response": [] }
      ]
    },
    {
      "name": "CDC Sources, Sinks & Observability",
      "item": [
        { "name": "List Source Types", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/sources", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "sources"] }, "description": "List available CDC source types (MySQL binlog, PostgreSQL WAL, etc.)" }, "response": [] },
        { "name": "List Sink Types", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/sinks", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "sinks"] }, "description": "List available CDC sink types (Kafka, Elasticsearch, S3, etc.)" }, "response": [] },
        { "name": "CDC Observability", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/cdc/observability", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "cdc", "observability"] }, "description": "CDC pipeline metrics: lag, throughput, errors" }, "response": [] }
      ]
    },
    {
      "name": "Data Platform",
      "item": [
        { "name": "Platform Overview", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/data-platform/overview", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "data-platform", "overview"] }, "description": "Unified overview of all ETL and CDC pipelines, datasources, and jobs" }, "response": [] }
      ]
    }
  ]
}
