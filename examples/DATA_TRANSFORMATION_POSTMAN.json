					"name": "Delete Rule",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/transform/rules/user_to_profile",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"transform",
								"rules",
								"user_to_profile"
							]
						},
						"description": "Delete a transformation rule"
					},
					"response": []
				}
			]
		},
		{
