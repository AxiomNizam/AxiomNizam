							"raw": "{{BASE_URL}}/api/transform/rules",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"transform",
								"rules"
							]
						},
						"description": "List all registered transformation rules"
					},
					"response": []
				},
