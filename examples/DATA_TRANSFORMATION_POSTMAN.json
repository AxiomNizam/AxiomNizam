						"body": {
							"mode": "raw",
							"raw": "{\n  \"data\": {\n    \"user\": {\n      \"id\": 123,\n      \"profile\": {\n        \"name\": \"John Doe\",\n        \"email\": \"john@example.com\",\n        \"address\": {\n          \"street\": \"123 Main St\",\n          \"city\": \"Anytown\",\n          \"country\": \"USA\"\n        }\n      },\n      \"roles\": [\"admin\", \"user\", \"editor\"]\n    }\n  },\n  \"config\": {\n    \"enabled\": true,\n    \"separator\": \"_\",\n    \"skip_null_value\": true\n  }\n}"
