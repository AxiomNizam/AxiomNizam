{
  "info": {
    "name": "AxiomNizam - Data Transformation",
    "description": "Data transformation rule management and execution endpoints. Create, apply, preview, test, export/import transformation rules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Rule Management",
      "item": [
        { "name": "Register Rule (Rename)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"rename_fields\",\n  \"type\": \"rename\",\n  \"description\": \"Rename user fields to camelCase\",\n  \"config\": {\n    \"mappings\": {\n      \"first_name\": \"firstName\",\n      \"last_name\": \"lastName\",\n      \"email_address\": \"emailAddress\"\n    }\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/rules", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules"] } }, "response": [] },
        { "name": "Register Rule (Type Conversion)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"convert_types\",\n  \"type\": \"type_conversion\",\n  \"description\": \"Convert string fields to proper types\",\n  \"config\": {\n    \"conversions\": {\n      \"age\": \"int\",\n      \"salary\": \"float\",\n      \"active\": \"bool\"\n    }\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/rules", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules"] } }, "response": [] },
        { "name": "Register Rule (Flatten)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"flatten_nested\",\n  \"type\": \"flatten\",\n  \"description\": \"Flatten nested objects\",\n  \"config\": {\n    \"separator\": \"_\",\n    \"max_depth\": 3\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/rules", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules"] } }, "response": [] },
        { "name": "List All Rules", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/transform/rules", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules"] } }, "response": [] },
        { "name": "Get Rule by Name", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/transform/rules/rename_fields", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules", "rename_fields"] } }, "response": [] },
        { "name": "Delete Rule", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/transform/rules/rename_fields", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules", "rename_fields"] } }, "response": [] }
      ]
    },
    {
      "name": "Rule Execution",
      "item": [
        { "name": "Apply Transformation", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"rule\": \"rename_fields\",\n  \"data\": {\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email_address\": \"john@example.com\"\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/apply", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "apply"] } }, "response": [] },
        { "name": "Batch Transform", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"rule\": \"rename_fields\",\n  \"data\": [\n    {\"first_name\": \"John\", \"last_name\": \"Doe\"},\n    {\"first_name\": \"Jane\", \"last_name\": \"Smith\"},\n    {\"first_name\": \"Bob\", \"last_name\": \"Johnson\"}\n  ]\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/batch", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "batch"] } }, "response": [] },
        { "name": "Preview Transformation", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"rule\": \"rename_fields\",\n  \"data\": {\n    \"first_name\": \"Preview\",\n    \"last_name\": \"Test\"\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/preview", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "preview"] } }, "response": [] }
      ]
    },
    {
      "name": "Test Operations",
      "item": [
        { "name": "Test Field Rename", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"data\": {\"old_field\": \"value1\", \"another_old\": \"value2\"},\n  \"mappings\": {\"old_field\": \"newField\", \"another_old\": \"anotherNew\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/test/rename", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "test", "rename"] } }, "response": [] },
        { "name": "Test Type Conversion", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"data\": {\"age\": \"30\", \"salary\": \"50000.50\", \"active\": \"true\"},\n  \"conversions\": {\"age\": \"int\", \"salary\": \"float\", \"active\": \"bool\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/test/types", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "test", "types"] } }, "response": [] },
        { "name": "Test Flattening", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"data\": {\n    \"user\": {\n      \"name\": \"John\",\n      \"address\": {\n        \"city\": \"New York\",\n        \"zip\": \"10001\"\n      }\n    }\n  }\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/test/flatten", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "test", "flatten"] } }, "response": [] }
      ]
    },
    {
      "name": "Import / Export",
      "item": [
        { "name": "Export All Rules", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/transform/rules/export", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules", "export"] } }, "response": [] },
        { "name": "Import Rules", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"rules\": [\n    {\n      \"name\": \"imported_rename\",\n      \"type\": \"rename\",\n      \"description\": \"Imported rename rule\",\n      \"config\": {\"mappings\": {\"old_name\": \"newName\"}}\n    },\n    {\n      \"name\": \"imported_types\",\n      \"type\": \"type_conversion\",\n      \"description\": \"Imported type conversion\",\n      \"config\": {\"conversions\": {\"count\": \"int\"}}\n    }\n  ]\n}" }, "url": { "raw": "{{BASE_URL}}/api/transform/rules/import", "host": ["{{BASE_URL}}"], "path": ["api", "transform", "rules", "import"] } }, "response": [] }
      ]
    }
  ]
}
