							"mode": "raw",
							"raw": "{\n  \"rule_name\": \"user_to_profile\",\n  \"data\": [\n    {\n      \"id\": 1,\n      \"name\": \"Alice Smith\",\n      \"email\": \"alice@example.com\",\n      \"age\": 28\n    },\n    {\n      \"id\": 2,\n      \"name\": \"Bob Johnson\",\n      \"email\": \"bob@example.com\",\n      \"age\": 35\n    },\n    {\n      \"id\": 3,\n      \"name\": \"Carol Williams\",\n      \"email\": \"carol@example.com\",\n      \"age\": 32\n    }\n  ]\n}"
