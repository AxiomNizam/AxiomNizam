								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"active_users_only\",\n  \"description\": \"Transform only active users\",\n  \"filters\": [\n    {\n      \"field\": \"status\",\n      \"operator\": \"eq\",\n      \"value\": \"active\"\n    },\n    {\n      \"field\": \"age\",\n      \"operator\": \"gte\",\n      \"value\": 18\n    }\n  ],\n  \"field_mappings\": {\n    \"id\": \"user_id\",\n    \"name\": \"full_name\"\n  },\n  \"type_conversions\": {\n    \"id\": \"string\",\n    \"age\": \"integer\"\n  }\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/transform/rules",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
