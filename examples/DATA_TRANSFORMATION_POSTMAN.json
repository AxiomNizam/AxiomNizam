	},
	"item": [
		{
			"name": "Rule Management",
			"item": [
				{
					"name": "Register New Transformation Rule",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"user_to_profile\",\n  \"description\": \"Convert user data to profile format\",\n  \"field_mappings\": {\n    \"id\": \"user_id\",\n    \"name\": \"full_name\",\n    \"email\": \"contact_email\"\n  },\n  \"type_conversions\": {\n    \"id\": \"string\"\n  }\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/transform/rules",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"transform",
								"rules"
							]
						},
						"description": "Register a new transformation rule with field mappings and type conversions"
					},
					"response": []
				},
				{
					"name": "Get Specific Rule",
					"request": {
						"method": "GET",
						"header": [],
