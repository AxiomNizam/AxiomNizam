{
  "info": {
    "name": "AxiomNizam - Network Intelligence",
    "description": "Network Intelligence dashboard API endpoints: log parsing, topology mapping, anomaly detection, alerting, traffic heatmaps, trend analysis, device tracking, and capacity forecasting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Overview",
      "item": [
        { "name": "Get Summary", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/summary", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "summary"] }, "description": "Overall network intelligence summary with key metrics" }, "response": [] },
        { "name": "Get Observability", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/observability", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "observability"] }, "description": "Network observability dashboard data" }, "response": [] },
        { "name": "Get Log Types", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/log-types", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "log-types"] }, "description": "List supported network log types" }, "response": [] }
      ]
    },
    {
      "name": "Log Parsers",
      "item": [
        { "name": "List Parsers", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/parsers", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "parsers"] } }, "response": [] },
        { "name": "Get Parser", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/parsers/parser-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "parsers", "parser-001"] } }, "response": [] },
        { "name": "Create Parser", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Syslog Parser\",\n  \"type\": \"syslog\",\n  \"pattern\": \"<priority>timestamp hostname app: message\",\n  \"enabled\": true,\n  \"description\": \"Parse standard syslog format\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/netintel/parsers", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "parsers"] } }, "response": [] },
        { "name": "Create Firewall Log Parser", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Firewall Log Parser\",\n  \"type\": \"firewall\",\n  \"pattern\": \"date=DATE time=TIME action=ACTION src=SRC dst=DST\",\n  \"enabled\": true,\n  \"description\": \"Parse firewall deny/allow logs\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/netintel/parsers", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "parsers"] } }, "response": [] },
        { "name": "Update Parser", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Syslog Parser v2\",\n  \"enabled\": false\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/netintel/parsers/parser-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "parsers", "parser-001"] } }, "response": [] },
        { "name": "Delete Parser", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/parsers/parser-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "parsers", "parser-001"] } }, "response": [] }
      ]
    },
    {
      "name": "Log Ingestion & Stats",
      "item": [
        { "name": "List Log Entries", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/logs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "logs"] } }, "response": [] },
        { "name": "Ingest Syslog Entry", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"source\": \"192.168.1.1\",\n  \"type\": \"syslog\",\n  \"raw\": \"<134>Oct 11 22:14:15 mymachine su: 'su root' failed for user on /dev/pts/1\",\n  \"severity\": \"warning\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/netintel/logs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "logs"] } }, "response": [] },
        { "name": "Ingest Firewall Log", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"source\": \"10.0.0.1\",\n  \"type\": \"firewall\",\n  \"raw\": \"date=2024-01-15 time=10:30:00 action=DENY src=192.168.1.100 dst=10.0.0.50 port=443\",\n  \"severity\": \"high\"\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/netintel/logs", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "logs"] } }, "response": [] },
        { "name": "Get Log Statistics", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/logs/stats", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "logs", "stats"] }, "description": "Get log ingestion statistics by type, severity, and source" }, "response": [] }
      ]
    },
    {
      "name": "Network Topology",
      "item": [
        { "name": "Get Full Topology", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/topology", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "topology"] }, "description": "Get complete network topology with nodes and edges" }, "response": [] },
        { "name": "Get Topology Node", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/topology/nodes/node-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "topology", "nodes", "node-001"] } }, "response": [] },
        { "name": "Update Topology Node", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\n  \"label\": \"Core Router - Updated\",\n  \"status\": \"maintenance\",\n  \"metadata\": {\"location\": \"DC-1\", \"model\": \"Cisco 9300\"}\n}" }, "url": { "raw": "{{BASE_URL}}/api/v1/netintel/topology/nodes/node-001", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "topology", "nodes", "node-001"] } }, "response": [] }
      ]
    },
    {
      "name": "Traffic Analysis",
      "item": [
        { "name": "Get Heatmap", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/heatmap", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "heatmap"] }, "description": "Traffic heatmap data for visualization" }, "response": [] },
        { "name": "Get Trends", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/trends", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "trends"] }, "description": "Traffic trend analysis over time" }, "response": [] },
        { "name": "Get Predictions", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/predictions", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "predictions"] }, "description": "ML-based traffic predictions" }, "response": [] }
      ]
    },
    {
      "name": "Device Tracking",
      "item": [
        { "name": "List All Tracks", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/tracks", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "tracks"] }, "description": "List all tracked network devices" }, "response": [] },
        { "name": "Get Track by MAC Address", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/tracks/AA:BB:CC:DD:EE:FF", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "tracks", "AA:BB:CC:DD:EE:FF"] }, "description": "Get movement history of a specific device by MAC address" }, "response": [] }
      ]
    },
    {
      "name": "Anomaly Detection",
      "item": [
        { "name": "List Anomalies", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/anomalies", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "anomalies"] }, "description": "List detected network anomalies" }, "response": [] },
        { "name": "Acknowledge Anomaly", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/anomalies/anomaly-001/acknowledge", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "anomalies", "anomaly-001", "acknowledge"] } }, "response": [] },
        { "name": "Resolve Anomaly", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/anomalies/anomaly-001/resolve", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "anomalies", "anomaly-001", "resolve"] } }, "response": [] }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        { "name": "List Alerts", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/alerts", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "alerts"] }, "description": "List active network alerts" }, "response": [] },
        { "name": "Acknowledge Alert", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/alerts/alert-001/acknowledge", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "alerts", "alert-001", "acknowledge"] } }, "response": [] },
        { "name": "Resolve Alert", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/alerts/alert-001/resolve", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "alerts", "alert-001", "resolve"] } }, "response": [] }
      ]
    },
    {
      "name": "Capacity Forecasting",
      "item": [
        { "name": "List All Forecasts", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/forecasts", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "forecasts"] }, "description": "Get all capacity forecasts" }, "response": [] },
        { "name": "Get Bandwidth Forecast", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/forecasts/bandwidth", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "forecasts", "bandwidth"] }, "description": "Bandwidth capacity forecast" }, "response": [] },
        { "name": "Get CPU Forecast", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/forecasts/cpu", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "forecasts", "cpu"] }, "description": "CPU utilization forecast" }, "response": [] },
        { "name": "Get Memory Forecast", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/v1/netintel/forecasts/memory", "host": ["{{BASE_URL}}"], "path": ["api", "v1", "netintel", "forecasts", "memory"] }, "description": "Memory utilization forecast" }, "response": [] }
      ]
    }
  ]
}
