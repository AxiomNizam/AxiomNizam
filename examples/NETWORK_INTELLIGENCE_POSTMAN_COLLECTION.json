				},
				{
					"name": "List Active Alerts",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/netintel/alerts?status=active",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "netintel", "alerts"],
							"query": [
								{ "key": "status", "value": "active" }
