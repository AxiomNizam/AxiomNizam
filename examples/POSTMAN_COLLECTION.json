        { "name": "Delete User", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "{{BASE_URL}}/api/mysql/users/1", "host": ["{{BASE_URL}}"], "path": ["api", "mysql", "users", "1"] } }, "response": [] }
